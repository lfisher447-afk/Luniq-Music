{
  "appId": "com.luniq.app",
  "productName": "Luniq",
  "compression": "maximum",
  "publish": [
    {
      "provider": "github",
      "owner": "saraansx",
      "repo": "Luniq-Music"
    }
  ],
  "asar": true,
  "asarUnpack": [
    "**/*.node",
    "**/node_modules/better-sqlite3/**/*"
  ],
  "extraResources": [
    {
      "from": "src/assets/Luniq.png",
      "to": "Luniq.png"
    },
    {
      "from": "src/assets/thumbar",
      "to": "thumbar"
    }
  ],
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron",
    "package.json"
  ],
  "win": {
    "icon": "src/assets/Luniq.png",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "uninstallDisplayName": "Luniq",
    "include": "build/installer.nsh",
    "license": "LicENSE",
    "shortcutName": "Luniq",
    "runAfterFinish": false,
    "createDesktopShortcut": false,
    "createStartMenuShortcut": true,
    "artifactName": "${productName}-Setup-${version}.${ext}"
  }
}